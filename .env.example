# Sudarshan Environment Configuration
# Copy this to .env and fill in your API keys

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── MobSF (optional — Androguard fallback used if not set) ──────────────────
# Run: docker run -it --rm -p 8008:8000 opensecurity/mobile-security-framework-mobsf:latest
MOBSF_HOST=http://localhost:8008
MOBSF_API_KEY=

# ─── Threat Intelligence APIs (optional — gracefully skipped if not set) ──────
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AlienVault OTX: https://otx.alienvault.com/api
OTX_API_KEY=

# AbuseIPDB: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=
